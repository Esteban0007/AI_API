# Environment variables for the application
# Copy this to .env and adjust values as needed

# API Configuration
API_TITLE=Semantic Search SaaS API
API_VERSION=1.0.0
API_DESCRIPTION=A FastAPI-based semantic search platform with vector embeddings and cross-encoder re-ranking

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Embedding Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Search Configuration
TOP_K=10
RERANK_TOP_K=5
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# Database Configuration
CHROMA_COLLECTION_NAME=documents
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# CORS Configuration (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000
